# Directory containing one auth.json per seat (absolute path).
# Each .json file name (without extension) is used as the seat id.
# Leave empty and set DEMO_MODE=1 to run with mock data (no real auth or API).
SEATS_DIRECTORY=

# Set to 1, true, or yes to serve mock seat list and status (no SEATS_DIRECTORY or API needed).
# DEMO_MODE=1

# Optional: override Codex usage API (defaults shown).
# CODEX_USAGE_BASE_URL=https://chatgpt.com/backend-api
# CODEX_USAGE_PATH=wham/usage

# Optional: protect API routes with a shared secret.
# When set, every request must include header `x-dashboard-secret: <value>`
# or query param `?secret=<value>` (query is disabled by default in production).
# DASHBOARD_SECRET=
#
# Optional: explicitly allow query-param secret auth in production (not recommended).
# ALLOW_DASHBOARD_SECRET_QUERY=1

# Optional: auto-refresh interval in ms when "Auto-refresh" is enabled (default 60000).
# NEXT_PUBLIC_AUTO_REFRESH_INTERVAL_MS=60000
